// Helper functions to check paths
function getColabUrl(path) {
  if (path && path.includes('github.com') && path.endsWith('.ipynb')) {
    return path.replace('github.com', 'colab.research.google.com/github');
  }
  return null;
}

function isGitHubUrl(path) {
  return path && path.includes('github.com');
}
